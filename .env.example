# RAG System - 全局环境变量配置模板
# 复制此文件为 .env 并填入真实的密钥

# ==================== OpenAI API 配置 ====================
# 用于 RAG 应用的 LLM 服务
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# ==================== SiliconFlow API 配置 ====================
# 用于标签提取和用户建模的 LLM 服务
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ==================== Neo4j 数据库配置 ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ==================== ChromaDB 配置 ====================
CHROMA_PERSIST_DIR=./04_RAG_APP/vector_store
CHROMA_COLLECTION_NAME=ev_comments

# ==================== 数据路径配置 ====================
RAW_DATA_DIR=./00_Raw_Data
CLEANED_DATA_DIR=./01_SSE_Analysis/1_Data_Preprocessing/outputs
MODEL_OUTPUT_DIR=./02_User_Modeling
GRAPH_DATA_DIR=./03_Knowledge_Graph/data

# ==================== 模型配置 ====================
EMBEDDING_MODEL_PATH=./04_RAG_APP/models/bge-large-zh-v1.5
LLM_MODEL_NAME=gpt-4-turbo-preview
TEMPERATURE=0.7

# ==================== 应用配置 ====================
APP_PORT=8501
LOG_LEVEL=INFO
DEBUG_MODE=false

# ==================== 模块特定配置提示 ====================
# 各模块有独立的 .env.example 文件，提供更详细的配置说明：
# - 01_SSE_Analysis/.env.example - 数据预处理和标签提取
# - 02_User_Modeling/.env.example - 用户建模和聚类分析
# - 03_Knowledge_Graph/.env.example - 知识图谱构建
# - 04_RAG_APP/.env.example - RAG 应用运行配置
