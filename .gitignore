# RAG_System - Global .gitignore

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# ============================================
# Virtual Environment
# ============================================
venv/
env/
ENV/
.venv

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# Environment Variables
# ============================================
.env
.env.local

# ============================================
# Logs
# ============================================
*.log
logs/
*.jsonl

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
.DS_Store
Thumbs.db

# ============================================
# Data Directories (Generated/Runtime Data)
# ============================================

# Neo4j Database Files (可再生)
**/neo4j_data/
**/neo4j_logs/

# Vector Store (可再生)
**/vector_store/

# Chroma Database
**/chroma.sqlite3

# ============================================
# 01_SSE_Analysis - 数据预处理输出
# ============================================
# 保留: cleaned_comments.csv, 星愿.csv, 比亚迪海豹06GT.csv
# 忽略其他所有CSV文件
01_SSE_Analysis/1_Data_Preprocessing/outputs/*.csv
!01_SSE_Analysis/1_Data_Preprocessing/outputs/cleaned_comments.csv
!01_SSE_Analysis/1_Data_Preprocessing/outputs/星愿.csv
!01_SSE_Analysis/1_Data_Preprocessing/outputs/比亚迪海豹06GT.csv

# ============================================
# 02_User_Modeling - 产品IPA分析输出
# ============================================
# 保留: 宝马i7 M70_IPA.png, 蔚来ET5T_IPA.png
# 忽略其他所有PNG文件
02_User_Modeling/Product_IPA_Analysis/outputs/*.png
!02_User_Modeling/Product_IPA_Analysis/outputs/宝马i7 M70_IPA.png
!02_User_Modeling/Product_IPA_Analysis/outputs/蔚来ET5T_IPA.png

# 保留其他文件类型（CSV, JSON, MD等）
!02_User_Modeling/Product_IPA_Analysis/outputs/*.csv
!02_User_Modeling/Product_IPA_Analysis/outputs/*.json
!02_User_Modeling/Product_IPA_Analysis/outputs/*.md

# ============================================
# 02_User_Modeling - 用户聚类输出
# ============================================
# 保留所有PNG图片
!02_User_Modeling/User_Preference_Clustering/outputs/*.png

# ============================================
# Models (预训练模型缓存)
# ============================================
**/models/
**/.cache/

# ============================================
# Jupyter Notebooks
# ============================================
.ipynb_checkpoints/
*.ipynb

# ============================================
# Docker
# ============================================
docker-compose.override.yml

# ============================================
# Docs / Paper Figures (始终追踪)
# ============================================
# 确保 docs/images 下的图片可以被推送
!docs/
!docs/**
!docs/images/
!docs/images/**
